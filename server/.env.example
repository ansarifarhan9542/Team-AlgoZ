# Copy this file to .env for local development.
# On Render, set these as Environment Variables in the dashboard instead of using a file.

# Server
NODE_ENV=production
PORT=5000
CLIENT_URL=https://your-frontend-domain.com

# Comma-separated list of allowed origins for CORS. Use "*" only for local/dev testing.
CORS_ORIGINS=https://your-frontend-domain.com

# Database (MongoDB Atlas connection string)
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/hrms?retryWrites=true&w=majority

# JWT
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRE=7d

# Email (SMTP) - used for verification / password reset / notifications
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=HRMS <no-reply@hrms.com>
